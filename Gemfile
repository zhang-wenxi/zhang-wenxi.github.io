source "https://rubygems.org"

# This bundle includes Jekyll and standard GitHub plugins
gem "github-pages", group: :jekyll_plugins

# REQUIRED: This tells Jekyll how to download your remote theme
gem "jekyll-remote-theme", group: :jekyll_plugins

# REQUIRED for Minimal Mistakes performance
gem "jekyll-include-cache", group: :jekyll_plugins

# REQUIRED for local testing (Jekyll serve) on Ruby 3.0+
gem "webrick", "~> 1.8"
